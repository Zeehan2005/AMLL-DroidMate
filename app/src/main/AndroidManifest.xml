<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 11+ package visibility: allow resolving launchable apps for source-app name and jump -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <!-- 权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DroidMate"
        android:usesCleartextTraffic="true">

        <activity
            android:name="com.amll.droidmate.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DroidMate">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 歌词显示Activity -->
        <activity
            android:name="com.amll.droidmate.ui.LyricsActivity"
            android:exported="false"
            android:theme="@style/Theme.DroidMate" />

        <activity
            android:name="com.amll.droidmate.ui.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.DroidMate" />

        <activity
            android:name="com.amll.droidmate.ui.FontSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.DroidMate" />

        <activity
            android:name="com.amll.droidmate.ui.CustomLyricsActivity"
            android:exported="false"
            android:theme="@style/Theme.DroidMate" />

        <activity
            android:name="com.amll.droidmate.ui.LyricsCacheActivity"
            android:exported="false"
            android:theme="@style/Theme.DroidMate" />

        <!-- 后台歌词监听服务 -->
        <service
            android:name="com.amll.droidmate.service.MediaListenerService"
            android:enabled="true"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

    </application>

</manifest>
